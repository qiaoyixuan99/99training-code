/* === 全局样式 === */

/* 颜色变量（通过CSS变量实现） */
page {
  --bg-primary: #0f0f1a;
  --bg-secondary: #1a1a2e;
  --bg-card: #16213e;
  --bg-card-hover: #1a2744;
  --text-primary: #ffffff;
  --text-secondary: #a0a0b8;
  --text-muted: #5a5a78;
  --gold: #ffd700;
  --gold-dark: #c8a600;
  --green: #00e676;
  --red: #ff5252;
  --blue: #448aff;
  --border: #2a2a3e;
  --radius: 16rpx;
  --radius-sm: 8rpx;
  --radius-lg: 24rpx;

  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用卡片样式 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 24rpx;
  margin: 16rpx 24rpx;
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--gold), var(--gold-dark));
  color: #1a1a2e;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 48rpx;
  text-align: center;
  border: none;
}
.btn-primary:active {
  opacity: 0.8;
}

.btn-outline {
  background: transparent;
  color: var(--gold);
  border: 2rpx solid var(--gold);
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 14rpx 48rpx;
  text-align: center;
}

/* 通用flex布局 */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-1 { flex: 1; }

/* 文本工具 */
.text-gold { color: var(--gold); }
.text-green { color: var(--green); }
.text-red { color: var(--red); }
.text-muted { color: var(--text-muted); }
.text-secondary { color: var(--text-secondary); }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 44rpx; }
.text-bold { font-weight: 700; }

/* 间距 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-16 { margin-bottom: 16rpx; }
.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-muted);
}
.empty-state .icon { font-size: 80rpx; margin-bottom: 24rpx; }

/* 滚动容器 */
.scroll-container {
  height: 100%;
  overflow-y: auto;
}
