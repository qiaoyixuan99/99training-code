/* AI分析页样式 */
.page-container {
  min-height: 100vh;
  background: #0d1117;
  padding-bottom: 40rpx;
}

/* 头部 */
.analysis-header {
  background: linear-gradient(135deg, #1a2332 0%, #0d2137 100%);
  padding: 32rpx;
  border-bottom: 1rpx solid #21262d;
}
.header-stock {
  margin-bottom: 16rpx;
}
.hs-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #f0f6fc;
  margin-right: 16rpx;
}
.hs-code {
  font-size: 24rpx;
  color: #8b949e;
}
.header-point {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.hp-label {
  font-size: 26rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  background: rgba(88,166,255,0.15);
  color: #58a6ff;
  border-radius: 8rpx;
}
.hp-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #f0f6fc;
}

/* 加载 */
.loading-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 24rpx;
}
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #21262d;
  border-top-color: #58a6ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  font-size: 28rpx;
  color: #8b949e;
}

/* 卡片 */
.analysis-content {
  padding: 24rpx;
}
.card {
  background: #161b22;
  border: 1rpx solid #21262d;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #f0f6fc;
  margin-bottom: 16rpx;
  display: block;
}
.card-subtitle {
  font-size: 24rpx;
  color: #8b949e;
}
.summary-card {
  background: linear-gradient(135deg, #1a2332 0%, #0d2137 100%);
  border-color: #1f6feb33;
}

/* 数据网格 */
.detail-grid {
  display: flex;
  flex-wrap: wrap;
}
.detail-item {
  width: 50%;
  padding: 12rpx 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.detail-label {
  font-size: 22rpx;
  color: #8b949e;
}
.detail-value {
  font-size: 26rpx;
  color: #f0f6fc;
  font-weight: 500;
}

/* 信号列表 */
.signal-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #21262d;
}
.signal-item:last-child { border-bottom: none; }
.signal-icon { font-size: 28rpx; flex-shrink: 0; margin-top: 2rpx; }
.signal-text {
  font-size: 26rpx;
  color: #c9d1d9;
  line-height: 1.5;
}
.signal-item.strong .signal-text { color: #f59e0b; }
.signal-item.positive .signal-text { color: #22c55e; }
.signal-item.warning .signal-text { color: #ef4444; }

/* AI文本 */
.analysis-text {
  font-size: 26rpx;
  color: #c9d1d9;
  line-height: 1.8;
}
.highlight-card {
  border-color: rgba(88,166,255,0.3);
  background: #0d2137;
}

/* 免责 */
.disclaimer {
  padding: 24rpx;
  text-align: center;
}
.disclaimer text {
  font-size: 22rpx;
  color: #484f58;
  line-height: 1.6;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: center;
  padding: 16rpx;
  gap: 24rpx;
}
.action-btn {
  padding: 16rpx 48rpx;
  background: #21262d;
  border: 1rpx solid #30363d;
  border-radius: 24rpx;
  color: #c9d1d9;
  font-size: 26rpx;
}
.action-btn:active { background: #30363d; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 48rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #c9d1d9; }
.empty-hint { font-size: 24rpx; color: #8b949e; margin-top: 8rpx; }

/* 头部价格信息 */
.header-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}
.hi-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #f0f6fc;
}
.hi-change {
  font-size: 26rpx;
}
.hi-change.up { color: #ef4444; }
.hi-change.down { color: #22c55e; }

/* 工具栏 */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #161b22;
  border-bottom: 1rpx solid #21262d;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 引擎状态指示器 */
.engine-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
}
.engine-status.online {
  background: rgba(34, 197, 94, 0.1);
  color: #22c55e;
}
.engine-status.offline {
  background: rgba(139, 148, 158, 0.1);
  color: #8b949e;
}
.es-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.engine-status.online .es-dot { background: #22c55e; box-shadow: 0 0 8rpx #22c55e; }
.engine-status.offline .es-dot { background: #484f58; }

/* 周期选择 */
.period-bar {
  display: flex;
  gap: 8rpx;
}
.period-item {
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #8b949e;
  background: #0d1117;
  border: 1rpx solid #21262d;
}
.period-item.active {
  color: #58a6ff;
  background: rgba(88, 166, 255, 0.1);
  border-color: #1f6feb;
}

/* 策略列表 */
.strategy-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #21262d;
}
.strategy-item:last-child { border-bottom: none; }
.st-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.st-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #58a6ff;
}
.st-confidence {
  font-size: 22rpx;
  color: #8b949e;
}
.st-signals { margin-top: 8rpx; }
.st-signal {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}
.sts-label {
  font-size: 22rpx;
  font-weight: 600;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}
.st-signal.positive .sts-label { background: rgba(34,197,94,0.15); color: #22c55e; }
.st-signal.warning .sts-label { background: rgba(239,68,68,0.15); color: #ef4444; }
.st-signal.info .sts-label { background: rgba(88,166,255,0.1); color: #58a6ff; }
.sts-value {
  font-size: 24rpx;
  color: #c9d1d9;
}
.st-reason {
  font-size: 24rpx;
  color: #8b949e;
}

/* 预测列表 */
.predict-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #21262d;
  flex-wrap: wrap;
}
.predict-item:last-child { border-bottom: none; }
.pi-name {
  font-size: 24rpx;
  color: #58a6ff;
  font-weight: 500;
  min-width: 120rpx;
}
.pi-direction { font-size: 24rpx; color: #f0f6fc; font-weight: 600; }
.pi-target { font-size: 24rpx; color: #f59e0b; }
.pi-horizon { font-size: 22rpx; color: #8b949e; }
.pi-confidence { font-size: 22rpx; color: #8b949e; }
