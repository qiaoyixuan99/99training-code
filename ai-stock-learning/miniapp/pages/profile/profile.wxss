/* 个人中心样式 */
.page-container {
  min-height: 100vh;
  background: #0d1117;
  padding-bottom: 40rpx;
}

/* 头部 */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #161b22 0%, #0d1117 100%);
}
.app-logo { font-size: 72rpx; margin-bottom: 12rpx; }
.app-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #f0f6fc;
}
.app-ver {
  font-size: 22rpx;
  color: #484f58;
  margin-top: 4rpx;
}

/* 统计 */
.stats-row {
  display: flex;
  margin: 24rpx 32rpx;
  gap: 16rpx;
}
.stat-card {
  flex: 1;
  background: #161b22;
  border: 1rpx solid #21262d;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #58a6ff;
}
.stat-label {
  font-size: 22rpx;
  color: #8b949e;
}

/* 菜单 */
.menu-section {
  margin: 24rpx 32rpx 0;
}
.menu-title {
  font-size: 22rpx;
  color: #8b949e;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  background: #161b22;
  padding: 24rpx;
  border-bottom: 1rpx solid #21262d;
}
.menu-item:first-of-type { border-radius: 12rpx 12rpx 0 0; }
.menu-item:last-of-type { border-radius: 0 0 12rpx 12rpx; border-bottom: none; }
.menu-item:only-of-type { border-radius: 12rpx; border-bottom: none; }
.mi-icon { font-size: 32rpx; margin-right: 16rpx; }
.mi-text { flex: 1; font-size: 28rpx; color: #c9d1d9; }
.mi-badge {
  font-size: 22rpx;
  color: #8b949e;
  background: #21262d;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
}
.mi-arrow { font-size: 28rpx; color: #484f58; }

/* 历史列表 */
.history-list {
  margin: 0 32rpx;
  background: #161b22;
  border-radius: 0 0 12rpx 12rpx;
  border: 1rpx solid #21262d;
  border-top: none;
  overflow: hidden;
}
.history-header {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  font-size: 22rpx;
  color: #8b949e;
}
.clear-btn { color: #ef4444; }
.history-item {
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #21262d;
}
.hi-stock { font-size: 26rpx; color: #f0f6fc; font-weight: 500; }
.hi-point { font-size: 22rpx; color: #8b949e; margin-left: 12rpx; }
.hi-time { font-size: 20rpx; color: #484f58; display: block; margin-top: 4rpx; }
.history-empty {
  padding: 32rpx;
  text-align: center;
  color: #8b949e;
  font-size: 24rpx;
}

/* 免责 */
.disclaimer {
  margin-top: 48rpx;
  padding: 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.disclaimer text {
  font-size: 22rpx;
  color: #484f58;
  line-height: 1.6;
}
