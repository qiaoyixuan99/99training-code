/* 自选页样式 */
.page-container {
  min-height: 100vh;
  background: #0d1117;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #161b22;
  border-bottom: 1rpx solid #21262d;
}
.page-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f0f6fc;
}
.edit-btn {
  font-size: 26rpx;
  color: #58a6ff;
  padding: 8rpx 16rpx;
}

.loading-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 12rpx;
  background: #0d2137;
  font-size: 22rpx;
  color: #58a6ff;
}
.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #58a6ff;
  animation: pulse 1s ease infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* 股票条目 */
.stock-list {
  background: #161b22;
}
.stock-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #21262d;
  position: relative;
}
.stock-item:active { background: #1c2333; }

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ef4444;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.delete-btn text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.si-left {
  flex: 1;
}
.si-name {
  font-size: 30rpx;
  color: #f0f6fc;
  font-weight: 500;
  display: block;
}
.si-code {
  font-size: 22rpx;
  color: #8b949e;
  margin-top: 4rpx;
}

.si-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}
.si-price {
  font-size: 32rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}
.si-change {
  font-size: 22rpx;
}
.si-price.muted { color: #8b949e; font-size: 28rpx; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 48rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #c9d1d9; }
.empty-hint { font-size: 24rpx; color: #8b949e; margin-top: 8rpx; }
