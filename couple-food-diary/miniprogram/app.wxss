/* 情侣美食记 - 全局样式 */

/* CSS 变量定义 */
page {
  --primary: #FF7EB3;
  --primary-light: #FFB3CC;
  --primary-lighter: #FFE0EC;
  --primary-dark: #E8609A;
  --bg: #FFF0F5;
  --bg-card: #FFFFFF;
  --text: #333333;
  --text-secondary: #888888;
  --text-light: #BBBBBB;
  --border: #F5E0E8;
  --shadow: 0 4rpx 16rpx rgba(255, 126, 179, 0.15);
  --radius: 20rpx;
  --radius-sm: 12rpx;
  --radius-lg: 28rpx;

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 24rpx;
  margin: 16rpx 24rpx;
}

/* 粉色按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

/* 次要按钮 */
.btn-secondary {
  background: #FFFFFF;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 圆角图片 */
.img-round {
  border-radius: var(--radius-sm);
  overflow: hidden;
}

/* 标签 */
.tag {
  display: inline-block;
  background: var(--primary-lighter);
  color: var(--primary-dark);
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* Flex 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-wrap {
  display: flex;
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* 文字样式 */
.text-primary {
  color: var(--primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-sm {
  font-size: 24rpx;
}

.text-lg {
  font-size: 34rpx;
}

.text-bold {
  font-weight: 700;
}

.text-center {
  text-align: center;
}

/* 间距 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 16rpx 0;
}

/* 甜蜜动画 */
@keyframes heartBeat {
  0%, 100% { transform: scale(1); }
  15% { transform: scale(1.3); }
  30% { transform: scale(1); }
  45% { transform: scale(1.15); }
  60% { transform: scale(1); }
}

@keyframes floatUp {
  0% { transform: translateY(0) scale(1); opacity: 1; }
  100% { transform: translateY(-200rpx) scale(1.5); opacity: 0; }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  75% { transform: translateX(8rpx); }
}

@keyframes slideInRight {
  from { transform: translateX(100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

@keyframes fadeInUp {
  from { transform: translateY(30rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.heart-anim {
  animation: heartBeat 0.6s ease-in-out;
}

.float-anim {
  animation: floatUp 1s ease-out forwards;
  pointer-events: none;
}

.shake-anim {
  animation: shake 0.4s ease-in-out;
}

.slide-in {
  animation: slideInRight 0.35s ease-out;
}

.fade-in-up {
  animation: fadeInUp 0.4s ease-out;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: var(--text-secondary);
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx;
  color: var(--text-light);
  font-size: 24rpx;
}
