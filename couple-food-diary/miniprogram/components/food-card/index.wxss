.food-card {
  position: relative;
  width: 320rpx;
  padding: 0;
  overflow: hidden;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  background: var(--bg-card);
  transition: transform 0.2s;
}

.food-card:active {
  transform: scale(0.97);
}

.food-image {
  position: relative;
  width: 100%;
  height: 220rpx;
  border-radius: var(--radius) var(--radius) 0 0;
  overflow: hidden;
  background: var(--primary-lighter);
}

.food-image image {
  width: 100%;
  height: 100%;
}

.food-cal-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(255, 126, 179, 0.85);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.food-info {
  padding: 16rpx;
}

.food-name {
  font-size: 28rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.food-desc {
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.add-cart-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  transition: transform 0.2s;
}

.add-cart-btn:active {
  transform: scale(0.9);
}

.like-btn {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
