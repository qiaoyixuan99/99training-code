<view wx:if="{{food}}" class="page-detail fade-in-up">
  <!-- 图片轮播 -->
  <view class="image-swiper" bindtap="onPreviewImage">
    <swiper
      indicator-dots="{{true}}"
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#FF7EB3"
      current="{{currentImageIndex}}"
      bindchange="onImageChange"
    >
      <swiper-item wx:for="{{food.images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="swiper-image"></image>
      </swiper-item>
    </swiper>
  </view>

  <!-- 基本信息 -->
  <view class="card info-card">
    <view class="flex-between">
      <view class="flex-1">
        <view class="food-name text-lg text-bold">{{food.name}}</view>
        <view class="food-category mt-8">
          <text class="tag">{{food.categoryName}}</text>
          <text class="text-sm text-secondary">{{food.desc}}</text>
        </view>
      </view>
      <view class="heart-btn">
        <text>❤️</text>
      </view>
    </view>

    <!-- 价格 & 卡路里 -->
    <view class="flex-between mt-24">
      <view>
        <text class="text-primary" style="font-size:44rpx;font-weight:700">¥{{food.price}}</text>
        <text class="text-sm text-secondary" style="margin-left:8rpx">/ 份</text>
      </view>
      <view class="cal-badge">
        <text>🔥 {{food.calories}} kcal</text>
      </view>
    </view>
  </view>

  <!-- 情侣双人份 -->
  <view class="card double-card {{isDouble ? 'active' : ''}}" bindtap="onDoubleToggle">
    <view class="flex-between">
      <view class="flex-row">
        <text style="font-size:48rpx;margin-right:16rpx">💑</text>
        <view>
          <view class="text-bold">情侣双人份</view>
          <view class="text-sm text-secondary">两份享受，甜蜜加倍 ❤️</view>
        </view>
      </view>
      <view class="double-price">
        <text wx:if="{{isDouble}}" class="text-primary text-bold">¥{{getDoublePrice()}}</text>
        <text wx:else class="text-secondary">88折</text>
      </view>
    </view>
    <view wx:if="{{isDouble}}" class="double-notice mt-16">
      <text>🎉 情侣特惠88折：原价¥{{(food.price * 2).toFixed(2)}}，现价¥{{getDoublePrice()}}</text>
    </view>
  </view>

  <!-- 营养成分 -->
  <view class="card nutrition-card">
    <view class="section-title text-bold">📊 营养成分</view>
    <view class="nutrition-grid">
      <view class="nutrition-item">
        <text class="nut-value">{{food.nutrition.protein || 0}}g</text>
        <text class="nut-label">蛋白质</text>
      </view>
      <view class="nutrition-item">
        <text class="nut-value">{{food.nutrition.fat || 0}}g</text>
        <text class="nut-label">脂肪</text>
      </view>
      <view class="nutrition-item">
        <text class="nut-value">{{food.nutrition.carbs || 0}}g</text>
        <text class="nut-label">碳水</text>
      </view>
      <view class="nutrition-item">
        <text class="nut-value">{{food.nutrition.fiber || 0}}g</text>
        <text class="nut-label">膳食纤维</text>
      </view>
    </view>
  </view>

  <!-- 制作流程 -->
  <view wx:if="{{food.steps && food.steps.length > 0}}" class="card steps-card">
    <view class="section-title text-bold">👨‍🍳 制作流程</view>
    <view class="steps-list">
      <view wx:for="{{food.steps}}" wx:key="index" class="step-item">
        <view class="step-num">{{index + 1}}</view>
        <view class="step-content">
          <text>{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 甜蜜动画 -->
  <view wx:for="{{loveAnimations}}" wx:key="id" class="love-float" style="left:{{item.x}}rpx;bottom:{{item.y}}rpx">
    <text>{{item.text}}</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar safe-bottom">
    <view class="quantity-control">
      <view class="qty-btn" bindtap="onQuantityMinus">
        <text>-</text>
      </view>
      <text class="qty-num">{{quantity}}</text>
      <view class="qty-btn" bindtap="onQuantityPlus">
        <text>+</text>
      </view>
    </view>
    <button class="btn-cart" bindtap="onAddToCart">加入购物车</button>
    <button class="btn-buy" bindtap="onBuyNow">立即购买</button>
  </view>

  <view style="height:120rpx"></view>
</view>

<!-- 加载中 -->
<view wx:else class="empty-state">
  <text>加载中… 💕</text>
</view>
