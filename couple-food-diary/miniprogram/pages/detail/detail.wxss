.page-detail {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 160rpx;
}

/* 图片轮播 */
.image-swiper {
  width: 100%;
  height: 500rpx;
  background: var(--primary-lighter);
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 信息卡片 */
.info-card {
  margin-top: -28rpx;
  border-radius: var(--radius-lg) var(--radius-lg) var(--radius) var(--radius);
  position: relative;
  z-index: 1;
}

.heart-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--primary-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.cal-badge {
  background: var(--primary-lighter);
  color: var(--primary-dark);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* 情侣双人份卡片 */
.double-card {
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.double-card.active {
  border-color: var(--primary);
  background: linear-gradient(135deg, #FFF0F5, #FFE0EC);
}

.double-price {
  font-size: 32rpx;
}

.double-notice {
  background: rgba(255, 126, 179, 0.1);
  padding: 12rpx 20rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  color: var(--primary-dark);
  text-align: center;
}

/* 区块标题 */
.section-title {
  font-size: 30rpx;
  margin-bottom: 20rpx;
  color: var(--text);
}

/* 营养成分 */
.nutrition-grid {
  display: flex;
  justify-content: space-around;
}

.nutrition-item {
  text-align: center;
}

.nut-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.nut-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 制作流程 */
.steps-list {
  padding-left: 0;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.step-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-top: 2rpx;
}

.step-content {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text);
  padding: 8rpx 16rpx;
  background: #FFF8FA;
  border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--primary-light);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.quantity-control {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--primary-lighter);
  color: var(--primary-dark);
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-num {
  font-size: 30rpx;
  font-weight: 600;
  margin: 0 16rpx;
  min-width: 48rpx;
  text-align: center;
}

.btn-cart {
  flex: 1;
  background: #FFFFFF;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 0;
  margin-right: 12rpx;
  text-align: center;
  line-height: 1.4;
}

.btn-buy {
  flex: 1;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #FFFFFF;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 0;
  text-align: center;
  line-height: 1.4;
}

.btn-buy::after {
  border: none;
}

.btn-cart::after {
  border: none;
}

.love-float {
  position: fixed;
  bottom: 200rpx;
  z-index: 999;
  animation: floatUp 1s ease-out forwards;
  pointer-events: none;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

@keyframes floatUp {
  0% { opacity: 1; transform: translateY(0) scale(0.8); }
  50% { opacity: 1; transform: translateY(-100rpx) scale(1.2); }
  100% { opacity: 0; transform: translateY(-200rpx) scale(1); }
}
