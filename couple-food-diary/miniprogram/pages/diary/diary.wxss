.page-diary {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

/* 日期切换 */
.date-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #FFFFFF;
  margin-bottom: 16rpx;
}

.date-arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg);
  border-radius: 50%;
}

.date-display {
  text-align: center;
  margin: 0 32rpx;
}

.date-text {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
}

.weekday {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 卡路里卡片 */
.cal-card {
  margin: 0 24rpx 16rpx;
}

.cal-progress {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.cal-circle {
  text-align: center;
  margin-bottom: 16rpx;
}

.cal-num {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.cal-percent {
  color: var(--primary);
  margin-top: 4rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: var(--primary-lighter);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-light), var(--primary));
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* 餐组 */
.meal-group {
  margin: 0 24rpx 16rpx;
}

.meal-header {
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border);
  margin-bottom: 12rpx;
}

.meal-items {
  padding-top: 4rpx;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed var(--border);
  position: relative;
}

.meal-item:last-child {
  border-bottom: none;
}

.meal-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-sm);
  margin-right: 12rpx;
  flex-shrink: 0;
  background: var(--primary-lighter);
}

.meal-empty {
  padding: 24rpx 0;
  text-align: center;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 0;
  padding: 4rpx 8rpx;
}

/* 7天趋势图 */
.week-card {
  margin: 0 24rpx 16rpx;
}

.week-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 260rpx;
  padding-top: 20rpx;
}

.chart-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.chart-bar {
  width: 48rpx;
  background: linear-gradient(to top, var(--primary-light), var(--primary));
  border-radius: 8rpx 8rpx 0 0;
  display: flex;
  font-size: 18rpx;
  color: #FFFFFF;
  align-items: flex-start;
  justify-content: center;
  padding-top: 4rpx;
  min-height: 8rpx;
  position: relative;
}

.bar-val {
  position: absolute;
  top: -28rpx;
  color: var(--text-secondary);
  font-size: 18rpx;
}

.chart-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.love-float {
  position: fixed;
  bottom: 200rpx;
  z-index: 999;
  animation: floatUp 1s ease-out forwards;
  pointer-events: none;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

@keyframes floatUp {
  0% { opacity: 1; transform: translateY(0) scale(0.8); }
  50% { opacity: 1; transform: translateY(-100rpx) scale(1.2); }
  100% { opacity: 0; transform: translateY(-200rpx) scale(1); }
}
