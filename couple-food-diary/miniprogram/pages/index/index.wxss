/* 首页样式 */
.page-index {
  min-height: 100vh;
  background: var(--bg);
}

/* 自定义导航栏 */
.nav-bar {
  background: linear-gradient(135deg, #FF7EB3, #FFB3CC);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-title-text {
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin: 16rpx 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

/* 分类滚动栏 */
.category-scroll {
  white-space: nowrap;
  padding: 8rpx 24rpx 16rpx;
  display: flex;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  margin-right: 16rpx;
  background: #FFFFFF;
  border-radius: 36rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  transition: all 0.3s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.category-tag.active {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 126, 179, 0.3);
}

.cat-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

/* 食品网格 */
.food-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 24rpx;
}

.food-grid > food-card {
  margin-bottom: 20rpx;
}

/* 浮动爱心动画 */
.love-float {
  position: fixed;
  bottom: 200rpx;
  z-index: 999;
  animation: floatUp 1s ease-out forwards;
  pointer-events: none;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  text-shadow: 0 2rpx 4rpx rgba(255, 126, 179, 0.3);
}

@keyframes floatUp {
  0% { opacity: 1; transform: translateY(0) scale(0.8); }
  50% { opacity: 1; transform: translateY(-100rpx) scale(1.2); }
  100% { opacity: 0; transform: translateY(-200rpx) scale(1); }
}
