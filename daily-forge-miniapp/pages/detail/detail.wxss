/* ──────────────────────────────────────
   Daily Forge — 详情页样式
   ────────────────────────────────────── */

/* ═══ 主题变量（黑夜） ═══ */
.app {
  --bg: #0f1117;
  --surface: #1a1d27;
  --surface2: #22263a;
  --border: #2a2e3f;
  --text: #e4e6f0;
  --text2: #9a9db5;
  --text3: #636883;
  --gold: #f0b90b;
  --gold2: #c99400;
  --xp: #00d4aa;
  --xp2: #009e7e;
  --streak: #ff6b6b;
  --morning: #f0a050;
  --noon: #ffd700;
  --afternoon: #60b0f0;
  --evening: #7c5ce7;
  --danger: #e0556a;
  --radius: 28rpx;
  --radius-sm: 20rpx;

  min-height: 100vh;
  background: var(--bg);
  color: var(--text);
  padding-bottom: 40rpx;
}

/* ═══ 主题变量（白天） ═══ */
.app.light-theme {
  --bg: #f5f5f7;
  --surface: #ffffff;
  --surface2: #f0f0f5;
  --border: #e0e0e6;
  --text: #1d1d26;
  --text2: #6e6e80;
  --text3: #9a9ab0;
  --gold: #c99400;
  --gold2: #a07800;
  --xp: #009e7e;
  --xp2: #007a60;
  --streak: #e04545;
  --morning: #d07020;
  --noon: #c9a000;
  --afternoon: #3078c0;
  --evening: #5a3ec8;
  --danger: #c04050;
}

/* ═══ 导航栏 ═══ */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 24rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
}

.nav-bar-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.nav-back {
  font-size: 36rpx;
  color: var(--gold);
  font-weight: 700;
}

.nav-back-text {
  font-size: 28rpx;
  color: var(--text2);
}

.nav-bar-center {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nav-icon {
  font-size: 36rpx;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.nav-search-icon {
  font-size: 36rpx;
  padding: 8rpx;
}

/* ═══ 搜索面板 ═══ */
.search-panel {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease;
  background: var(--surface);
  border-bottom: 2rpx solid var(--border);
}

.search-panel.show {
  max-height: 600rpx;
}

.search-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  background: var(--surface2);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--text);
}

.search-btn {
  background: var(--gold);
  color: #000;
  padding: 16rpx 32rpx;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 600;
}

.search-btn:active {
  opacity: 0.8;
}

.search-loading {
  text-align: center;
  padding: 24rpx;
  color: var(--text3);
  font-size: 26rpx;
}

.search-results {
  padding: 0 32rpx 20rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.search-result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 20rpx;
  background: var(--surface2);
  border-radius: var(--radius-sm);
  margin-bottom: 10rpx;
}

.search-result-item:active {
  background: var(--border);
}

.result-name {
  font-size: 26rpx;
  color: var(--text);
  flex: 1;
}

.result-source {
  font-size: 22rpx;
  color: var(--text3);
  margin-left: 16rpx;
}

/* ═══ 概述卡片 ═══ */
.overview-card {
  margin: 24rpx 32rpx;
  background: linear-gradient(135deg, #1a1d30 0%, #1d2035 100%);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
}

.app.light-theme .overview-card {
  background: linear-gradient(135deg, #f8f7ff 0%, #f0eff8 100%);
}

.overview-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.overview-icon {
  font-size: 56rpx;
}

.overview-info {
  flex: 1;
}

.overview-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
}

.overview-subtitle {
  font-size: 24rpx;
  color: var(--text3);
  display: block;
  margin-top: 4rpx;
}

.overview-text {
  font-size: 26rpx;
  color: var(--text2);
  line-height: 1.7;
}

/* ═══ Tab 栏 ═══ */
.tab-bar {
  display: flex;
  gap: 8rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.tab-bar::-webkit-scrollbar {
  display: none;
}

.tab-item {
  flex-shrink: 0;
  padding: 14rpx 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: 32rpx;
  transition: all 0.2s;
}

.tab-item.active {
  border-color: var(--gold);
  background: var(--surface2);
}

.tab-text {
  font-size: 24rpx;
  color: var(--text3);
  white-space: nowrap;
}

.tab-item.active .tab-text {
  color: var(--gold);
  font-weight: 600;
}

/* ═══ 内容区域 ═══ */
.content-area {
  padding: 0 32rpx;
}

.section-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s ease;
}

/* Section 头部 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.section-type-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.badge-study { background: #14283a; color: var(--afternoon); }
.badge-listen { background: #2a1a4a; color: var(--evening); }
.badge-tips { background: #3a3510; color: var(--noon); }
.badge-method { background: #0f1a17; color: var(--xp); }
.badge-template { background: #3a2a14; color: var(--morning); }
.badge-reference { background: #14283a; color: var(--afternoon); }
.badge-roadmap { background: #2a1a4a; color: var(--evening); }
.badge-code { background: #0f1a17; color: var(--xp); }

/* Section 内容 */
.section-body {
  margin-bottom: 28rpx;
}

.section-desc {
  font-size: 28rpx;
  color: var(--text2);
  line-height: 1.8;
}

/* 子标题 */
.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
  display: block;
}

/* ═══ 步骤列表 ═══ */
.steps-list {
  margin-bottom: 28rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: var(--surface);
  border-radius: var(--radius-sm);
  margin-bottom: 10rpx;
}

.step-num {
  min-width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: var(--gold);
  color: #000;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 700;
}

.step-text {
  font-size: 26rpx;
  color: var(--text2);
  line-height: 1.6;
  flex: 1;
  padding-top: 4rpx;
}

/* ═══ 技巧列表 ═══ */
.tips-list {
  margin-bottom: 28rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.tip-item:last-child {
  border-bottom: none;
}

.tip-bullet {
  color: var(--gold);
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
  padding-top: 2rpx;
}

.tip-text {
  font-size: 26rpx;
  color: var(--text2);
  line-height: 1.6;
}

/* ═══ 模板列表 ═══ */
.template-list {
  margin-bottom: 28rpx;
}

.template-item {
  padding: 14rpx 20rpx;
  background: var(--surface);
  border-radius: var(--radius-sm);
  margin-bottom: 8rpx;
}

.template-text {
  font-size: 26rpx;
  color: var(--text2);
  line-height: 1.6;
}

/* ═══ 示例卡片 ═══ */
.example-card {
  margin-bottom: 28rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 24rpx;
}

.example-original,
.example-analysis,
.example-simplified {
  margin-bottom: 16rpx;
}

.example-original:last-child,
.example-analysis:last-child,
.example-simplified:last-child {
  margin-bottom: 0;
}

.example-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--gold);
  display: block;
  margin-bottom: 8rpx;
}

.example-text {
  font-size: 26rpx;
  color: var(--text2);
  line-height: 1.7;
}

/* ═══ 词汇分类 ═══ */
.categories-list {
  margin-bottom: 28rpx;
}

.category-card {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--gold);
  display: block;
  margin-bottom: 8rpx;
}

.category-words {
  font-size: 24rpx;
  color: var(--text2);
  line-height: 1.6;
}

/* ═══ 课程列表 ═══ */
.courses-list {
  margin-bottom: 28rpx;
}

.course-card {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.course-card:active {
  border-color: var(--gold);
  transform: scale(0.98);
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.course-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  flex: 1;
}

.course-difficulty {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.diff-入门 { background: #0f1a17; color: var(--xp); }
.diff-中级 { background: #3a3510; color: var(--noon); }
.diff-高级 { background: #3a1a1a; color: var(--streak); }

.course-desc {
  font-size: 24rpx;
  color: var(--text2);
  display: block;
  margin-bottom: 12rpx;
}

.course-link {
  font-size: 24rpx;
  color: var(--gold);
}

/* ═══ 里程碑 ═══ */
.milestones-list {
  margin-bottom: 28rpx;
}

.milestone-card {
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.milestone-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.milestone-level {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--gold);
  background: var(--surface2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.milestone-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.milestone-items {
  padding-left: 8rpx;
}

.milestone-item {
  font-size: 24rpx;
  color: var(--text2);
  line-height: 1.8;
  display: block;
}

/* ═══ 资源链接 ═══ */
.resources-list {
  margin-bottom: 28rpx;
}

.resource-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  margin-bottom: 10rpx;
  transition: all 0.2s;
}

.resource-item:active {
  border-color: var(--gold);
  transform: scale(0.98);
}

.resource-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--text);
}

.resource-type {
  font-size: 22rpx;
  color: var(--text3);
  background: var(--surface2);
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.resource-arrow {
  font-size: 36rpx;
  color: var(--text3);
  font-weight: 300;
}

/* ═══ 底部安全区 ═══ */
.safe-bottom {
  height: 60rpx;
}
