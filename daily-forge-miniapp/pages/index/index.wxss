/* ──────────────────────────────────────
   Daily Forge — 主页样式
   CSS 变量定义在 .app 容器上实现动态主题切换
   ────────────────────────────────────── */

/* ═══ 主题变量（黑夜模式 — 默认） ═══ */
.app {
  --bg: #0f1117;
  --surface: #1a1d27;
  --surface2: #22263a;
  --border: #2a2e3f;
  --text: #e4e6f0;
  --text2: #9a9db5;
  --text3: #636883;
  --gold: #f0b90b;
  --gold2: #c99400;
  --xp: #00d4aa;
  --xp2: #009e7e;
  --streak: #ff6b6b;
  --morning: #f0a050;
  --noon: #ffd700;
  --afternoon: #60b0f0;
  --evening: #7c5ce7;
  --danger: #e0556a;
  --radius: 28rpx;
  --radius-sm: 20rpx;

  min-height: 100vh;
  background: var(--bg);
  color: var(--text);
  padding-bottom: 80rpx;
}

/* ═══ 主题变量（白天模式） ═══ */
.app.light-theme {
  --bg: #f5f5f7;
  --surface: #ffffff;
  --surface2: #f0f0f5;
  --border: #e0e0e6;
  --text: #1d1d26;
  --text2: #6e6e80;
  --text3: #9a9ab0;
  --gold: #c99400;
  --gold2: #a07800;
  --xp: #009e7e;
  --xp2: #007a60;
  --streak: #e04545;
  --morning: #d07020;
  --noon: #c9a000;
  --afternoon: #3078c0;
  --evening: #5a3ec8;
  --danger: #c04050;
}

/* 白天模式下的特别覆盖 */
.app.light-theme .badge-morning { background: #fef0e0; }
.app.light-theme .badge-noon { background: #fff8dc; }
.app.light-theme .badge-afternoon { background: #e0eefc; }
.app.light-theme .badge-evening { background: #e8e0fa; }
.app.light-theme .task-card.completed { background: #eafaf4; border-color: var(--xp); }
.app.light-theme .week-day.done { background: #eafaf4; }
.app.light-theme .identity-banner { background: linear-gradient(135deg, #1a1d30 0%, #1d2035 100%); }
.app.light-theme .identity-banner { background: linear-gradient(135deg, #f8f7ff 0%, #f0eff8 100%); }

/* ═══ 自定义导航栏 ═══ */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 32rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
}

.nav-date {
  font-size: 26rpx;
  color: var(--text3);
  display: block;
}

.nav-title {
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text);
}

.gold { color: var(--gold); }

/* ═══ 主题切换 ═══ */
.theme-toggle {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  color: var(--text2);
  font-size: 24rpx;
  transition: all 0.2s;
}

.theme-toggle:active {
  transform: scale(0.95);
  border-color: var(--gold);
  color: var(--gold);
}

/* ═══ 统计卡片 ═══ */
.stats-row {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 28rpx;
}

.stat-card {
  flex: 1;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text3);
  margin-top: 6rpx;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  display: block;
}

.stat-card.streak .stat-value { color: var(--streak); }
.stat-card.xp .stat-value { color: var(--xp); }
.stat-card.level .stat-value { color: var(--gold); }

/* ═══ XP 进度条 ═══ */
.xp-section {
  padding: 0 32rpx;
  margin-bottom: 28rpx;
}

.xp-header {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text2);
  margin-bottom: 10rpx;
}

.xp-bar-outer {
  height: 14rpx;
  background: var(--surface2);
  border-radius: 7rpx;
  overflow: hidden;
}

.xp-bar-inner {
  height: 100%;
  background: linear-gradient(90deg, var(--xp2), var(--xp));
  border-radius: 7rpx;
  transition: width 0.5s ease;
}

/* ═══ 身份横幅 ═══ */
.identity-banner {
  margin: 0 32rpx 28rpx;
  background: linear-gradient(135deg, #1a1d30 0%, #1d2035 100%);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx 32rpx;
  text-align: center;
}

.identity-title {
  font-size: 22rpx;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  display: block;
}

.identity-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--gold);
  margin: 8rpx 0;
  display: block;
}

.identity-sub {
  font-size: 24rpx;
  color: var(--text2);
}

/* ═══ 区块标题 ═══ */
.section-title {
  font-size: 24rpx;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 18rpx;
  display: block;
  padding: 0 32rpx;
}

.section-gap {
  margin-top: 36rpx;
}

/* ═══ 任务卡片 ═══ */
.task-card {
  margin: 0 32rpx 20rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx;
  transition: all 0.25s;
  position: relative;
}

.task-card.completed {
  border-color: var(--xp);
  background: #0f1a17;
}

/* 已完成勾号 */
.task-card.completed::after {
  content: '✓';
  position: absolute;
  top: 24rpx;
  right: 32rpx;
  font-size: 40rpx;
  color: var(--xp);
  font-weight: 700;
}

.task-time-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
  letter-spacing: 0.03em;
}

.badge-morning { background: #3a2a14; color: var(--morning); }
.badge-noon { background: #3a3510; color: var(--noon); }
.badge-afternoon { background: #14283a; color: var(--afternoon); }
.badge-evening { background: #2a1a4a; color: var(--evening); }

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
  display: block;
  color: var(--text);
}

.task-desc {
  font-size: 26rpx;
  color: var(--text2);
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.task-xp {
  font-size: 24rpx;
  color: var(--xp);
  font-weight: 500;
}

/* ═══ 反思区 ═══ */
.reflection-area {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border);
}

.reflection-prompt {
  font-size: 24rpx;
  color: var(--text2);
  margin-bottom: 14rpx;
  font-style: italic;
  display: block;
}

.reflection-input {
  width: 100%;
  min-height: 120rpx;
  background: var(--surface2);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: var(--text);
  box-sizing: border-box;
}

.reflection-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

/* ═══ 按钮 ═══ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 18rpx 36rpx;
  border-radius: 40rpx;
  border: none;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.2s;
  line-height: 1.2;
}

.btn::after {
  border: none;
}

.btn-complete {
  background: var(--surface2);
  color: var(--text);
  border: 2rpx solid var(--border);
  padding: 18rpx 36rpx;
  font-size: 26rpx;
}

.btn-complete:active {
  border-color: var(--xp);
  color: var(--xp);
  transform: scale(0.96);
}

.btn-save {
  background: var(--xp);
  color: #000;
  padding: 14rpx 32rpx;
  font-size: 24rpx;
  flex: 1;
}

.btn-save:active {
  background: var(--xp2);
  transform: scale(0.96);
}

.btn-undo {
  background: transparent;
  color: var(--text3);
  border: 2rpx solid var(--border);
  padding: 14rpx 24rpx;
  font-size: 24rpx;
}

/* ═══ 本周网格 ═══ */
.week-grid {
  display: flex;
  gap: 10rpx;
  padding: 0 32rpx;
  margin-bottom: 28rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  padding: 18rpx 6rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
}

.week-day.today {
  border-color: var(--gold);
}

.week-day.done {
  border-color: var(--xp);
  background: #0f1a17;
}

.week-day-name {
  font-size: 22rpx;
  color: var(--text);
}

.week-day-date {
  font-size: 20rpx;
  color: var(--text3);
  display: block;
  margin-top: 4rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  display: inline-block;
  margin-top: 8rpx;
}

.dot.all-done { background: var(--xp); }
.dot.partial { background: var(--gold); }
.dot.none { background: var(--border); }

/* ═══ 历史记录 ═══ */
.history-view {
  min-height: 400rpx;
}

.history-empty {
  color: var(--text3);
  text-align: center;
  padding: 64rpx 32rpx;
  font-size: 28rpx;
}

.history-item {
  margin: 0 32rpx 16rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24rpx;
}

.history-date {
  font-weight: 600;
  font-size: 28rpx;
  color: var(--text);
  display: block;
}

.history-summary {
  font-size: 24rpx;
  color: var(--text2);
  margin-top: 8rpx;
  display: block;
}

.history-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.history-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.tag-all-done { background: #0f1a17; color: var(--xp); }
.tag-eng { background: #14283a; color: var(--afternoon); }
.tag-agent { background: #2a1a4a; color: var(--evening); }
.tag-fail { background: #3a1a1a; color: #e0556a; }

/* ═══ 底部导航 ═══ */
.nav {
  display: flex;
  gap: 14rpx;
  padding: 0 32rpx;
  margin-top: 36rpx;
}

.nav-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 14rpx;
  background: var(--surface);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text2);
  font-size: 26rpx;
  transition: all 0.2s;
}

.nav-btn::after { border: none; }

.nav-btn.active {
  border-color: var(--gold);
  color: var(--gold);
}

/* ═══ 重置 ═══ */
.reset-area {
  margin-top: 48rpx;
  padding-bottom: 60rpx;
  text-align: center;
}

.btn-reset {
  background: transparent;
  border: 2rpx solid var(--border);
  color: var(--text3);
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.btn-reset::after { border: none; }

/* ═══ Toast ═══ */
.toast {
  position: fixed;
  top: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 26rpx 44rpx;
  border-radius: 48rpx;
  font-weight: 700;
  font-size: 28rpx;
  z-index: 999;
  pointer-events: none;
  animation: toastIn 0.4s ease;
}

.toast.crit {
  background: var(--gold);
  color: #000;
}

.toast.normal {
  background: var(--xp);
  color: #000;
}

.toast.streak-bonus {
  background: var(--streak);
  color: #fff;
}

.toast.level-up {
  background: linear-gradient(135deg, #f0b90b, #ff8c00);
  color: #000;
  font-size: 32rpx;
}

@keyframes toastIn {
  from { opacity: 0; transform: translateX(-50%) translateY(-40rpx); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}
