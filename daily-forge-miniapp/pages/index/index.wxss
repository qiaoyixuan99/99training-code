/* ──────────────────────────────────────
   Daily Forge — 主页样式
   极简高级感设计 · 双主题支持
   ────────────────────────────────────── */

/* ═══ 主题变量（黑夜模式） ═══ */
.app {
  --bg: #0d0e12;
  --surface: #16171d;
  --surface2: #1e1f27;
  --border: #2a2b33;
  --text: #e8e8ed;
  --text2: #8e8e9a;
  --text3: #5a5b66;
  --accent: #c99400;
  --accent2: #a07800;
  --xp: #009e7e;
  --xp2: #007a60;
  --streak: #d45050;
  --morning: #e09850;
  --noon: #c9a000;
  --afternoon: #5098d0;
  --evening: #7c5ce7;
  --danger: #c04050;
  --radius: 16rpx;
  --radius-sm: 12rpx;

  min-height: 100vh;
  background: var(--bg);
  color: var(--text);
  padding-bottom: 120rpx;
}

/* ═══ 主题变量（白天模式） ═══ */
.app.light-theme {
  --bg: #f5f5f7;
  --surface: #ffffff;
  --surface2: #f0f0f3;
  --border: #e5e5ea;
  --text: #1c1c24;
  --text2: #6e6e7a;
  --text3: #9a9aa8;
  --accent: #b8860b;
  --accent2: #926a08;
  --xp: #008a6a;
  --xp2: #006b50;
  --streak: #c04040;
  --morning: #c07030;
  --noon: #b89000;
  --afternoon: #3070a0;
  --evening: #6a4ad0;
  --danger: #b03848;
}

/* ═══ 白天模式覆盖 ═══ */
.app.light-theme .badge-morning { background: #fef5ea; }
.app.light-theme .badge-noon { background: #fef9e0; }
.app.light-theme .badge-afternoon { background: #eaf2fa; }
.app.light-theme .badge-evening { background: #f0eafa; }
.app.light-theme .task-card.completed { background: #f6faf8; border-color: var(--xp); border-left-width: 6rpx; }
.app.light-theme .week-day.done { background: #f6faf8; }

/* ═══ 自定义导航栏 ═══ */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx 40rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
}

.nav-date {
  font-size: 26rpx;
  color: var(--text3);
  display: block;
  letter-spacing: 0.02em;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: var(--text);
}

/* ═══ 主题切换 ═══ */
.theme-toggle {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: var(--surface2);
  border: 1rpx solid var(--border);
  color: var(--text2);
  font-size: 24rpx;
  transition: all 0.2s;
}

.theme-toggle:active {
  transform: scale(0.96);
  border-color: var(--accent);
  color: var(--accent);
}

/* ═══ 统计卡片 ═══ */
.stats-row {
  display: flex;
  gap: 12rpx;
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx 20rpx;
  text-align: center;
  transition: border-color 0.2s;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
  display: block;
  line-height: 1.1;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text3);
  margin-top: 8rpx;
  letter-spacing: 0.04em;
  display: block;
}

.stat-card.streak .stat-value { color: var(--streak); }
.stat-card.xp .stat-value { color: var(--xp); }
.stat-card.level .stat-value { color: var(--accent); }

/* ═══ XP 进度条 ═══ */
.xp-section {
  padding: 0 40rpx;
  margin-bottom: 36rpx;
}

.xp-header {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text2);
  margin-bottom: 12rpx;
  letter-spacing: 0.02em;
}

.xp-bar-outer {
  height: 8rpx;
  background: var(--surface2);
  border-radius: 4rpx;
  overflow: hidden;
}

.xp-bar-inner {
  height: 100%;
  background: var(--xp);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

/* ═══ 区块标题 ═══ */
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text2);
  letter-spacing: 0.04em;
  margin-bottom: 20rpx;
  display: block;
  padding: 0 40rpx;
}

.section-gap {
  margin-top: 40rpx;
}

/* ═══ 任务卡片 ═══ */
.task-card {
  margin: 0 40rpx 20rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius);
  padding: 32rpx;
  transition: all 0.25s;
  position: relative;
}

.task-card.completed {
  border-color: var(--xp);
  border-left-width: 6rpx;
}

.task-time-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  letter-spacing: 0.03em;
}

.badge-morning { background: #302418; color: var(--morning); }
.badge-noon { background: #2e2a14; color: var(--noon); }
.badge-afternoon { background: #142230; color: var(--afternoon); }
.badge-evening { background: #241840; color: var(--evening); }

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
  color: var(--text);
  letter-spacing: -0.01em;
}

.task-desc {
  font-size: 26rpx;
  color: var(--text2);
  margin-bottom: 22rpx;
  line-height: 1.7;
}

.task-xp {
  font-size: 24rpx;
  color: var(--xp);
  font-weight: 500;
}

/* ═══ 反思区 ═══ */
.reflection-area {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
}

.reflection-prompt {
  font-size: 24rpx;
  color: var(--text3);
  margin-bottom: 16rpx;
  display: block;
  line-height: 1.5;
}

.reflection-input {
  width: 100%;
  min-height: 120rpx;
  background: var(--surface2);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 18rpx 22rpx;
  font-size: 26rpx;
  color: var(--text);
  box-sizing: border-box;
  line-height: 1.6;
}

.reflection-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

/* ═══ 按钮 ═══ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 36rpx;
  border-radius: 24rpx;
  border: none;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s;
  line-height: 1.3;
  letter-spacing: 0.02em;
}

.btn::after {
  border: none;
}

.btn-complete {
  background: var(--surface2);
  color: var(--text);
  border: 1rpx solid var(--border);
  margin-top: 4rpx;
}

.btn-complete:active {
  border-color: var(--xp);
  color: var(--xp);
  transform: scale(0.97);
}

.btn-save {
  background: var(--xp);
  color: #fff;
  padding: 14rpx 32rpx;
  font-size: 24rpx;
  flex: 1;
}

.btn-save:active {
  background: var(--xp2);
  transform: scale(0.97);
}

.btn-undo {
  background: transparent;
  color: var(--text3);
  border: 1rpx solid var(--border);
  padding: 14rpx 24rpx;
  font-size: 24rpx;
}

.btn-undo:active {
  border-color: var(--danger);
  color: var(--danger);
}

/* ═══ 本周网格 ═══ */
.week-grid {
  display: flex;
  gap: 8rpx;
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  padding: 20rpx 6rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}

.week-day.today {
  border-color: var(--accent);
}

.week-day.done {
  border-color: var(--xp);
}

.week-day-name {
  font-size: 22rpx;
  color: var(--text2);
  font-weight: 500;
}

.week-day-date {
  font-size: 20rpx;
  color: var(--text3);
  display: block;
  margin-top: 4rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  display: inline-block;
  margin-top: 10rpx;
}

.dot.all-done { background: var(--xp); }
.dot.partial { background: var(--accent); }
.dot.none { background: var(--border); }

/* ═══ 历史记录 ═══ */
.history-view {
  min-height: 400rpx;
}

.history-empty {
  color: var(--text3);
  text-align: center;
  padding: 80rpx 40rpx;
  font-size: 28rpx;
}

.history-item {
  margin: 0 40rpx 16rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius);
  padding: 28rpx;
}

.history-date {
  font-weight: 600;
  font-size: 28rpx;
  color: var(--text);
  display: block;
  letter-spacing: -0.01em;
}

.history-summary {
  font-size: 24rpx;
  color: var(--text2);
  margin-top: 10rpx;
  display: block;
  line-height: 1.5;
}

.history-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.history-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.tag-all-done { background: #152820; color: var(--xp); }
.tag-eng { background: #162230; color: var(--afternoon); }
.tag-dev { background: #201a3a; color: var(--evening); }
.tag-fail { background: #2a1a1c; color: var(--danger); }

/* ═══ 底部导航 ═══ */
.nav {
  display: flex;
  gap: 12rpx;
  padding: 0 40rpx;
  margin-top: 40rpx;
}

.nav-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 14rpx;
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text2);
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s;
  letter-spacing: 0.02em;
}

.nav-btn::after { border: none; }

.nav-btn.active {
  border-color: var(--accent);
  color: var(--accent);
  font-weight: 600;
}

/* ═══ 重置 ═══ */
.reset-area {
  margin-top: 48rpx;
  padding-bottom: 80rpx;
  text-align: center;
}

.btn-reset {
  background: transparent;
  border: 1rpx solid var(--border);
  color: var(--text3);
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  line-height: 1.3;
  letter-spacing: 0.02em;
}

.btn-reset::after { border: none; }

/* ═══ Toast ═══ */
.toast {
  position: fixed;
  top: 140rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 24rpx 40rpx;
  border-radius: 24rpx;
  font-weight: 600;
  font-size: 28rpx;
  z-index: 999;
  pointer-events: none;
  animation: toastIn 0.3s ease;
  letter-spacing: 0.02em;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.25);
}

.toast.crit {
  background: var(--accent);
  color: #fff;
}

.toast.normal {
  background: var(--xp);
  color: #fff;
}

.toast.streak-bonus {
  background: var(--streak);
  color: #fff;
}

.toast.level-up {
  background: var(--accent);
  color: #fff;
  font-size: 30rpx;
}

@keyframes toastIn {
  from { opacity: 0; transform: translateX(-50%) translateY(-20rpx); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}
